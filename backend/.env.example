# Database
DATABASE_URL=sqlite+aiosqlite:///./sales_dashboard.db

# For PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Security (REQUIRED: change this!)
JWT_SECRET=change-this-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.pages.dev
